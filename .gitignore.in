#!/usr/bin/env bash
set -euo pipefail
cd "${0%/*}" && exec > .gitignore
gi() { curl -L -s https://www.gitignore.io/api/"$*"; }
# `gibo list' and `gi list'
gibo dump Linux
gibo dump Windows
gibo dump macOS
gibo dump Python
echo '.venv/'
echo '.mypy_cache/'
echo '.ruff_cache/'
echo 'src/agent_def_translator/_version.py'
echo 'generated/'
echo '.tmp/'
